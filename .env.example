# ─────────────────────────────────────────────────────
# SplunkOps MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# Splunk Cloud host (e.g. mystack.splunkcloud.com)
# For self-hosted Enterprise, use your server hostname/IP
SPLUNK_HOST=mystack.splunkcloud.com

# REST API port (default 8089 for both Cloud and Enterprise)
SPLUNK_PORT=8089

# Authentication token (recommended over username/password)
# Generate at: Settings → Tokens → New Token
SPLUNK_TOKEN=your-splunk-auth-token-here

# Set to false only for self-signed certs in dev environments
SPLUNK_VERIFY_SSL=true

# Default index to use when none is specified
SPLUNK_DEFAULT_INDEX=main

# Optional: max time (seconds) to wait for a search job to finish
SPLUNK_SEARCH_TIMEOUT=60
